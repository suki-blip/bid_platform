{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/auto-charge",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/purge-trash",
      "schedule": "0 4 * * *"
    }
  ]
}
